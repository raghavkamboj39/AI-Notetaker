{
  "name": "notetaker-fresh",
  "version": "1.0.0",
  "description": "AI-powered audio transcription and note-taking app",
  "main": "electron.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.ainotetaker.app",
    "productName": "AI Notetaker",
    "copyright": "Copyright © 2024",
    "files": [
      "electron.js",
      "main.js",
      "transcribe.js",
      "notesengine.js",
      "storage.js",
      "loop-reader.js",
      "fileparser.js",
      "index.html",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**/*",
      "node_modules/@ffmpeg-installer/win32-x64/**/*",
      "node_modules/@ffmpeg-installer/darwin-arm64/**/*",
      "node_modules/@ffmpeg-installer/darwin-x64/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "dmg": {
      "title": "AI Notetaker",
      "window": { "width": 540, "height": 380 }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Notetaker"
    }
  },
  "dependencies": {
    "@azure/msal-node": "^5.3.0",
    "@azure/storage-blob": "^12.32.0",
    "@ffmpeg-installer/darwin-arm64": "^4.1.5",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffmpeg-installer/win32-x64": "^4.1.0",
    "@google/genai": "^2.8.0",
    "adm-zip": "^0.5.17",
    "axios": "^1.18.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.6",
    "mammoth": "^1.8.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "multer": "^2.2.0",
    "openai": "^6.44.0",
    "pdf-parse": "^1.1.1",
    "xlsx": "^0.18.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^24.13.3"
  }
}